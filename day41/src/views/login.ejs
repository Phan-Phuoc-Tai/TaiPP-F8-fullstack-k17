<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang đăng nhập</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    
    <% if (error) { %>
      <p style="color: red;background: lightpink; text-align: center; font-size: 18px; line-height: 42px;"><%= error %></p>
    <% } %>

    <% if (success) { %>
      <p style="color: rgb(5, 164, 5) ;background: rgb(207, 249, 207); text-align: center; font-size: 18px; line-height: 42px"><%= success %></p>
    <% } %>
    
    <form action="/login" method="post" class="form-login">
      <h1>Đăng nhập</h1>
      <label for="email">Email</label>
      <input type="email" name="email" placeholder="Email..." id="email" />
      <label for="password">Mật khẩu</label>
      <input
        type="password"
        name="password"
        placeholder="Mật khẩu..."
        id="password"
      />
      <button class="submit-btn">Đăng nhập</button>
    </form>
  </body>
</html>
